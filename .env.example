# Brainrot Video Automator - Environment Variables

# ===================
# Supabase (Pre-configured)
# ===================
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# Client-side Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ===================
# Google Gemini API (Free Tier: 15 RPM)
# ===================
GEMINI_API_KEY=your_gemini_api_key_here

# Get your free API key at: https://makersuite.google.com/app/apikey

# ===================
# YouTube Data API v3
# ===================
YOUTUBE_CLIENT_ID=your_google_oauth_client_id
YOUTUBE_CLIENT_SECRET=your_google_oauth_client_secret
YOUTUBE_REDIRECT_URI=http://localhost:3000/api/oauth/youtube/callback

# Get credentials at: https://console.cloud.google.com/apis/credentials
# Required scopes: https://www.googleapis.com/auth/youtube.upload

# ===================
# Instagram Graph API
# ===================
INSTAGRAM_APP_ID=your_instagram_app_id
INSTAGRAM_APP_SECRET=your_instagram_app_secret
INSTAGRAM_REDIRECT_URI=http://localhost:3000/api/oauth/instagram/callback

# Get credentials at: https://developers.facebook.com/apps/
# Required permissions: instagram_basic, instagram_content_publish

# ===================
# Application Configuration
# ===================
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:3001

# Paths (container paths when using Docker)
TEMP_DIR=/app/temp
OUTPUT_DIR=/app/outputs

# ===================
# Scheduler Configuration (IST)
# ===================
SCHEDULE_MORNING=12:30
SCHEDULE_EVENING=19:30
TZ=Asia/Kolkata

# ===================
# Logging
# ===================
LOG_LEVEL=info
LOG_DIR=/app/logs

# ===================
# Feature Flags
# ===================
KEEP_TEMP_FILES=false
